# Используем стабильную версию Node.js
FROM node:18-slim

# Создаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем файлы зависимостей
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install --production

# Копируем весь остальной код галереи
COPY . .

# Открываем порт 3000
EXPOSE 3000

# Команда для запуска
CMD ["npm", "start"]
